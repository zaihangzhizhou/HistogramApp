<?xml version="1.0" encoding="utf-8"?>
<!--
  HistogramApp Android 清单文件

  声明应用的身份信息、所需权限、组件注册和系统级配置。
  此文件由 Android 系统在安装 APK 时解析，决定:
  - 应用的包名和版本
  - 需要的系统权限 (安装时提示用户授权)
  - Activity / Service / Receiver 等组件的注册
  - 原生库提取策略

  ==================== OpenCV 原生库说明 ====================
  1. OpenCV 的 .so 文件打包在 APK 的 lib/<ABI>/ 目录下
  2. extractNativeLibs="true" 确保系统安装时将 .so 提取到
     /data/app/<package>/lib/ 目录，使 System.loadLibrary() 可找到
  3. 支持的 ABI:
     - arm64-v8a: 主流 64 位 ARM (2020+ 几乎所有 Android 设备)
     - armeabi-v7a: 旧款 32 位 ARM
-->

<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      ========== 权限声明 ==========

      READ_EXTERNAL_STORAGE (API < 33):
        读取外部存储中的图片文件。Android 13 (API 33) 起被废弃，
        替代方案为 READ_MEDIA_IMAGES。

      READ_MEDIA_IMAGES (API 33+):
        细粒度媒体权限，仅读取图片 (不包含视频和音频)。
        与 READ_EXTERNAL_STORAGE 并存，运行时根据 API 级别自动选择生效。
    -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!--
      ========== 应用配置 ==========
    -->
    <application
        android:allowBackup="true"
        android:label="HistogramApp"
        android:extractNativeLibs="true"
        android:theme="@style/Theme.MaterialComponents.Light.NoActionBar">

        <!--
          ========== 主 Activity ==========

          exported="true": 允许外部组件启动此 Activity。
            - 必须为 true，因为 Launcher 需要从应用外部启动它
            - 如果设为 false，应用图标不会出现在桌面上

          intent-filter: 声明此 Activity 响应的 Intent 类型。
            - MAIN + LAUNCHER: 标记为应用入口，显示在桌面/应用抽屉中
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true">

            <!-- Launcher Intent 过滤器: 此 Activity 是应用的入口点 -->
            <intent-filter>
                <!-- 主入口动作 — 应用启动时由 Launcher 发送 -->
                <action android:name="android.intent.action.MAIN" />

                <!-- Launcher 类别 — 标记为桌面可启动的应用 -->
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
